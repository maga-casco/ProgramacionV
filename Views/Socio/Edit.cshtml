@model ProgramacionV.Models.SocioViewModel

@{
ViewData["Title"] = "Modificar Socio";
}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
    .usuario-card {
        max-width: 850px;
        margin: 40px auto;
        background: white;
        border-radius: 25px;
        padding: 40px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.08);
        font-family: 'Poppins', sans-serif;
    }

    .usuario-titulo {
        font-size: 2rem;
        font-weight: 700;
        color: #2d3748;
        margin-bottom: 8px;
    }

    .usuario-subtitulo {
        color: #718096;
        margin-bottom: 35px;
        font-size: .95rem;
    }

    .form-group {
        margin-bottom: 22px;
    }

    .form-label {
        display: block;
        margin-bottom: 8px;
        font-weight: 500;
        color: #4a5568;
    }

    .form-control {
        width: 100%;
        padding: 14px 18px;
        border: none;
        background: #f7f7fb;
        border-radius: 15px;
        font-size: 15px;
        font-family: 'Poppins', sans-serif;
        transition: all .3s ease;
    }

        .form-control:focus {
            outline: none;
            background: #f3efff;
            box-shadow: 0 0 0 3px rgba(167, 139, 250, .25);
        }

    .input-validation-error {
        border: 2px solid #ef4444 !important;
        background: #fef2f2 !important;
    }

    .text-danger {
        color: #dc2626 !important;
        font-size: .85rem;
        margin-top: 5px;
        display: block;
        font-weight: 500;
    }

    .text-danger {
        font-size: .85rem;
        margin-top: 5px;
        display: block;
    }

    .acciones {
        margin-top: 35px;
        display: flex;
        gap: 12px;
    }

    .btn-guardar {
        background: #a78bfa;
        color: white;
        border: none;
        border-radius: 15px;
        padding: 12px 28px;
        font-weight: 600;
        transition: .3s;
    }

        .btn-guardar:hover {
            background: #8b5cf6;
            transform: translateY(-2px);
        }

    .btn-volver {
        background: #f1f2f6;
        color: #4a5568;
        text-decoration: none;
        border-radius: 15px;
        padding: 12px 28px;
        font-weight: 500;
        transition: .3s;
    }

        .btn-volver:hover {
            background: #e2e8f0;
            color: #2d3748;
        }

    .icono {
        width: 70px;
        height: 70px;
        background: #f3efff;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 30px;
        margin-bottom: 20px;
    }

    .alerta-exito {
        max-width: 850px;
        margin: 25px auto -20px auto;
        background: #ecfdf5;
        border: 1px solid #86efac;
        color: #166534;
        border-radius: 18px;
        padding: 15px 20px;
        display: flex;
        align-items: center;
        gap: 14px;
        font-family: 'Poppins', sans-serif;
        box-shadow: 0 10px 25px rgba(34,197,94,0.12);
    }

    .alerta-icono {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: #22c55e;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        font-weight: bold;
    }

    .fila {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .input-validation-error {
        border: 2px solid #ef4444 !important;
        background: #fef2f2 !important;
    }

    .field-validation-error {
        color: #dc2626;
        font-size: .85rem;
        margin-top: 5px;
        display: block;
        font-weight: 500;
    }

    .field-validation-error {
        color: #dc2626;
        font-size: .85rem;
        font-weight: 500;
    }

    .alerta-error {
        background: #fef2f2;
        border: 1px solid #fca5a5;
        color: #b91c1c;
        border-radius: 15px;
        padding: 15px 20px;
        margin-bottom: 25px;
        font-family: 'Poppins', sans-serif;
        box-shadow: 0 8px 20px rgba(239,68,68,.10);
    }

        .alerta-error strong {
            display: block;
            margin-bottom: 4px;
        }
</style>

    <div class="usuario-card">

    <div class="icono">
        🏋️
    </div>

    <h1 class="usuario-titulo">
        Modificar Socio
    </h1>

    <p class="usuario-subtitulo">
        Modifique los datos correspondientes del socio en el gimnasio.
    </p>

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
    {
        <div class="alerta-error">
            <strong>⚠ Atención</strong>
            Complete los campos obligatorios.
        </div>
    }

    <form asp-action="Edit" method="post">

        <input asp-for="Id" type="hidden" />

    <div asp-validation-summary="ModelOnly"
         class="text-danger">
    </div>

    <div class="fila">

        <div class="form-group">
            <label asp-for="Nombre" class="form-label"></label>
            <input asp-for="Nombre"
                   class="form-control"
                   placeholder="Ingrese el nombre" />
                <span asp-validation-for="Nombre"
                      class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Apellido" class="form-label"></label>
            <input asp-for="Apellido"
                   class="form-control"
                   placeholder="Ingrese el apellido" />
            <span asp-validation-for="Apellido"
                  class="text-danger"></span>
        </div>

    </div>

    <div class="fila">

        <div class="form-group">
            <label asp-for="DNI" class="form-label"></label>
            <input asp-for="DNI"
                   class="form-control"
                   placeholder="Ingrese el DNI" />
            <span asp-validation-for="DNI"
                  class="text-danger"></span>
        </div>

            <div class="form-group">
                <label class="form-label">
                    Fecha de Nacimiento
                </label>

                <input asp-for="FechaNacimiento"
                       id="fechaNacimiento"
                       type="text"
                       class="form-control"
                       placeholder="dd/mm/aaaa"
                       maxlength="10" />

                <span asp-validation-for="FechaNacimiento"
                      class="text-danger"></span>
            </div>

    </div>

    <div class="fila">

        <div class="form-group">
            <label asp-for="Telefono"
                   class="form-label">
            </label>

            <input asp-for="Telefono"
                   class="form-control"
                   placeholder="Ingrese teléfono" />

            <span asp-validation-for="Telefono"
                  class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Email"
                   class="form-label">
            </label>

            <input asp-for="Email"
                   class="form-control"
                   placeholder="Ingrese email" />

            <span asp-validation-for="Email"
                  class="text-danger"></span>
        </div>

    </div>

    <div class="form-group">

        <label asp-for="Direccion"
               class="form-label">
        </label>

        <input asp-for="Direccion"
               class="form-control"
               placeholder="Ingrese dirección" />

        <span asp-validation-for="Direccion"
              class="text-danger"></span>

    </div>

        <div class="form-group">

            <label class="form-label">
                Estado del socio
            </label>

            <div style="display:flex; align-items:center; gap:10px;">

                <input asp-for="Activo"
                       type="checkbox"
                       style="width:20px; height:20px;" />

                <span>
                    Socio activo
                </span>

            </div>

            <span asp-validation-for="Activo"
                  class="text-danger"></span>

        </div>

    <div class="acciones">

        <button type="submit"
                class="btn btn-guardar">

            Guardar cambios

        </button>

        <a asp-action="Index"
           class="btn-volver">

            Volver

        </a>

    </div>

</form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");

        <script>

            document.getElementById("fechaNacimiento")
            .addEventListener("input", function (e) {

                let x = e.target.value.replace(/\D/g, "");

                if (x.length > 2)
                    x = x.slice(0, 2) + "/" + x.slice(2);

                if (x.length > 5)
                    x = x.slice(0, 5) + "/" + x.slice(5);

                e.target.value = x;

            });

        </script>
    }
}

