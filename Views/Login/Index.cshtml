@model ProgramacionV.Models.LoginViewModel

@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />

    <style>

            body {
                background: linear-gradient(135deg, #ffd6e8, #e0c3fc);
                height: 100vh;
                overflow: hidden;
                font-family: 'Segoe UI';
            }

            .login-container {
                height: 100vh;
            }

            .login-card {
                width: 400px;
                padding: 35px;
                border-radius: 25px;
                background: rgba(255,255,255,0.85);
                backdrop-filter: blur(10px);
                box-shadow: 0px 8px 30px rgba(0,0,0,0.15);
            }

            .titulo {
                color: #c061cb;
                font-weight: bold;
            }

            .form-control {
                border-radius: 12px;
                border: 1px solid #e4b5ff;
                padding: 10px;
            }

                .form-control:focus {
                    border-color: #d291ff;
                    box-shadow: 0 0 10px rgba(210,145,255,0.4);
                }

            .btn-login {
                background: linear-gradient(90deg, #ff9ecf, #c77dff);
                border: none;
                border-radius: 12px;
                padding: 10px;
                font-weight: bold;
                color: white;
                transition: 0.3s;
            }

                .btn-login:hover {
                    transform: scale(1.02);
                    opacity: 0.9;
                }

            .password-container {
                position: relative;
            }

            .toggle-password {
                position: absolute;
                top: 50%;
                right: 15px;
                transform: translateY(-50%);
                cursor: pointer;
                color: #c061cb;
            }

            .alert {
                border-radius: 12px;
            }

    </style>
</head>

<body>

    <div class="container d-flex justify-content-center align-items-center login-container">

        <div class="login-card">

            <h2 class="text-center mb-4 titulo">
                Iniciar Sesión
            </h2>

            <form asp-controller="Login" asp-action="Index" method="post">

                <div class="mb-3">
                    <label class="form-label">Usuario</label>
                    <input asp-for="Username" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Contraseña</label>

                    <div class="password-container">

                        <input asp-for="Password"
                               type="password"
                               class="form-control"
                               id="passwordInput" />

                        <i class="fa-solid fa-eye toggle-password"
                           id="togglePassword"></i>

                    </div>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-login">
                        Ingresar
                    </button>
                </div>

            </form>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mt-3">
                    @ViewBag.Error
                </div>
            }

        </div>

    </div>

    <script>

            const togglePassword =
                document.getElementById('togglePassword');

            const passwordInput =
                document.getElementById('passwordInput');

            togglePassword.addEventListener('click', function () {

                const type =
                    passwordInput.getAttribute('type') === 'password'
                    ? 'text'
                    : 'password';

                passwordInput.setAttribute('type', type);

                this.classList.toggle('fa-eye');
                this.classList.toggle('fa-eye-slash');
            });

    </script>

</body>
</html>